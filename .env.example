# Copy this file to .env and fill in your Supabase project's values.
# Project Settings -> API in the Supabase dashboard.
# See DentVerseDocs/13-setup-guides/backend-setup.md for full setup steps.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Milestone 7 — Voice-to-Chart. Base URL of the running orchestrator
# service (see orchestrator/.env.example). Defaults to the local dev
# port if unset, so this line is only needed when it's not localhost:3001.
VITE_ORCHESTRATOR_URL=http://localhost:3001
