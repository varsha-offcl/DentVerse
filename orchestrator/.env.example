# Milestone 0 — health check only. WhatsApp/Instagram/Facebook +
# AI Receptionist vars will be added starting Milestone 4/5.
# See DentVerseDocs/12-milestones.

PORT=3001

# Supabase — service-role key is used ONLY to verify a caller's bearer
# token belongs to a real signed-in user (see src/supabase-admin.ts).
# The orchestrator does not write to the database for Voice-to-Chart;
# it stays behind the same RLS-protected path manual entries use.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Milestone 7 — Voice-to-Chart AI pipeline.
# Groq is the MVP choice for both STT and structuring (free tier, no
# card, fast) — see STT_PROVIDER/LLM_PROVIDER in
# src/voice-to-chart/voice-to-chart.module.ts for how to swap either one
# out later (e.g. Sarvam AI for STT) without touching the controller.
GROQ_API_KEY=
STT_PROVIDER=groq
LLM_PROVIDER=groq
# Optional overrides — sensible defaults are baked in if unset.
# GROQ_STT_MODEL=whisper-large-v3
# GROQ_LLM_MODEL=llama-3.3-70b-versatile
